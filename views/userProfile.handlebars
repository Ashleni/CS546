<main>
    <h1>Your Profile</h1>

<a href="/inbox">Inbox Notifications {{#if unread}}({{unread}}){{else}}{{/if}}</a>

    {{#if user}}

        <h3>Username</h3>
        <p>{{user.userName}}</p>

        <h3>Name</h3>
        <p>{{user.firstName}} {{user.lastName}}</p>

        <h3>Account Type</h3>
        <p>{{role}}</p>

        <div id="tabResults" class="tabContent">
            <h2>
                Click to scroll to your posted contents
            </h2>

            <a href="#tab1">Following</a>
            <a href="#tab2">Reviews</a>
            <a href="#tab3">Comments</a>

            <h3 id="tab1">Following</h3>

            {{#if userFollows}}
            <ul>
                {{#each follows}}
                <li>
                    <a href="/restaurant/{{this.restaurantId}}">
                    {{this.name}}
                    </a>

                    {{#if this.isPublic}}
                    <span>Public</span>
                    {{else}}
                    <span>Private</span>
                    {{/if}}

                    <form action="/restaurant/{{this.restaurantId}}/follow/visibility" method="POST">
                    <select name="visibility">
                        <option value="public">Public</option>
                        <option value="private">Private</option>
                    </select>

                    <button type="submit">Change</button>
                    </form>

                    <form action="/restaurant/{{this.restaurantId}}/unfollow" method="POST">
                    <button type="submit">Unfollow</button>
                    </form>
                </li>
                {{/each}}
            </ul>

            {{else}}

            <p>You have no followed restaurants.</p>

            {{/if}}

            <h3 id="tab2">Reviews</h3>
            {{#if userReviews}}
                <ol>
                    {{#each reviews}}
                            <li class="review-item">
                                <!-- REWRITTEN
                                <span><strong>{{this.restaurant}}</strong></span><br>
                                Your Rating: {{this.rating}}/5 {{this.date}}<br>
                                <form action="/review/{{this.reviewId}}" method="POST" class="review-form inline-edit-form">
                                    <input type="hidden" name="_method" value="PUT">
                                    <label for="edit-rating-{{this.reviewId}}">
                                        New rating (0&ndash;5):
                                        <input type="number" name="rating" id="edit-rating-{{this.reviewId}}"
                                               min="0" max="5" step="0.1" value="{{this.rating}}" required>
                                    </label>
                                    <button type="submit">Update</button>
                                </form>
                                
                                -->


                            <div class="review-item-header">
                                <strong>{{this.restaurant}}</strong>
                                <span class="review-rating-badge">&#9733; {{this.rating}}/5</span>
                            </div>
                            <p class="review-item-text">{{this.reviewText}}</p>
                            {{#if this.hasPhotos}}
                                <p class="review-photo-note"> {{this.photoCount}} photo(s) attached</p>
                            {{/if}}
                            <p class="review-item-meta">
                                Posted {{this.date}}{{#if this.edited}} | <em>edited</em>{{/if}}
                            </p>
                            <a href="/review/{{this.reviewId}}/edit" class="btn-secondary btn-sm">Edit Review</a>
                            <a href="/restaurant/{{this.restaurantId}}" class="btn-link">View Restaurant</a>


                            </li>
                    {{/each}}
                </ol>
            {{else}} <p>You have no posted reviews</p>
            {{/if}}

            <h3 id="tab3">Comments</h3>
            {{#if userComments}}
                <ol>
                    {{#each comments}}
                        <li>
                            Restaurant: {{this.restaurant}} <br>
                            Your Comment: {{this.message}} <br>
                            Date: {{this.date}}
                        </li>
                    {{/each}}
                </ol>
            {{else}} <p>You have no posted comments</p>
            {{/if}}
        </div>

    {{else}}
        <a class="profileNoUser" href="/signin">To view your profile, sign in!</a>
        or
        <a class="profileNoUser" href="/register">register to view it</a>
    {{/if}}
</main>