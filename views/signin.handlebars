<main>

      <div id="error" class="formError" {{#unless error}}style="display:none"{{/unless}}>{{error}}</div> <!-- Please stop deleting this, this line prevents the empty error box bug. --> 

<form action="/signin" method="POST" id="signin-form">
    <label for="username">
        Username
        <input type="text" name="username" id="username">
    </label>
    <label for="password">
        Password
        <input type="password" name="password" id="password">
    </label>
    <button type="submit" name="submit_button" id="submit_button">Sign In</button> 
</form>

<a id="registerlink" href="/register">Don't have an account? Sign-up!</a>

<script src="../public/js/signin.js"></script>

</main>