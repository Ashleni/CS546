<main></main>
  <h1>NYC Restaurant Map</h1>
  <p>Click a pin to view a restaurant's profile.</p>

  <div id="map" style="height: 600px; width: 100%;"></div>

  <!-- Leaflet CSS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <!-- Leaflet JS -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <script>
    // Borough center coordinates for NYC boroughs
    const boroughCoords = {
      "Manhattan":    [40.7831, -73.9712],
      "Brooklyn":     [40.6782, -73.9442],
      "Queens":       [40.7282, -73.7949],
      "Bronx":        [40.8448, -73.8648],
      "Staten Island":[40.5795, -74.1502],
    };

    // Initialize map centered on NYC
    const map = L.map("map").setView([40.7128, -74.0060], 11);

    // Add OpenStreetMap tiles (free, no API key needed)
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 18,
    }).addTo(map);

    // Inject restaurants from server
    const restaurants = {{{restaurantsJSON}}};

    // Add a marker for each restaurant using borough coordinates
    // (We don't have exact lat/lng per restaurant, so we cluster by borough with slight random offset)
    restaurants.forEach(r => {
      const base = boroughCoords[r.boro];
      if (!base) return; // skip if no boro listed

      // Add small random offset so pins don't all stack on one point
      const lat = base[0] + (Math.random() - 0.5) * 0.05;
      const lng = base[1] + (Math.random() - 0.5) * 0.05;

      const marker = L.marker([lat, lng]).addTo(map);
      marker.bindPopup(
        `<strong>${r.name}</strong><br>` +
        `${r.boro || "Unknown Borough"}<br>` +
        `Cuisine: ${r.cuisine || "N/A"}<br>` +
        `<a href="/restaurant/${r._id}">View Profile →</a>`
      );
    });
  </script>
</main>